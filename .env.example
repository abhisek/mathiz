# Configuration for `mathiz serve` (the SaaS server).
# Copy to .env and `set -a; source .env; set +a` (or use your process manager).

# --- Database (required) ---
# Dev: local PostgreSQL from `make dev-db`.
# Prod: Supabase's connection string or any hosted PostgreSQL.
MATHIZ_DATABASE_URL=postgres://mathiz:mathiz@localhost:5432/mathiz?sslmode=disable

# --- Supabase auth (parents) ---
# Project URL: used for JWKS verification, issuer validation, and SPA boot config.
MATHIZ_SUPABASE_URL=https://your-project.supabase.co
# Anon (publishable) key: served to the SPA; public by design.
MATHIZ_SUPABASE_ANON_KEY=your-anon-key
# Legacy JWT secret (Project Settings → API → JWT Secret). Enables HS256
# verification. Optional if your project uses asymmetric signing keys (JWKS).
MATHIZ_SUPABASE_JWT_SECRET=

# --- Server ---
MATHIZ_SERVER_ADDR=:8080
# MATHIZ_SESSION_IDLE_MINUTES=30
# MATHIZ_CORS_ORIGINS=            # only for split SPA deployments
# MATHIZ_TRUST_PROXY=true         # behind a reverse proxy: rate-limit by X-Forwarded-For

# --- Logging ---
# One structured (canonical) log line per request, always on stdout.
# MATHIZ_LOG_FILE=/var/log/mathiz.log  # also append to this file (tee); startup fails if unopenable
# MATHIZ_LOG_FORMAT=text               # text (default, key=value) | json
# MATHIZ_LOG_LEVEL=info                # debug | info | warn | error
# No built-in rotation — rotate externally (logrotate, or your container
# runtime's log driver).

# --- Billing / monetisation (optional) ---
# Empty = billing disabled, everything free (self-hoster default).
# "fake" = dev provider: checkout succeeds instantly, no real money.
# "stripe" = real payments; requires the MATHIZ_STRIPE_* + price vars below
# and MATHIZ_PUBLIC_BASE_URL. Webhook endpoint: POST /api/v1/billing/webhook
# (events: checkout.session.completed, invoice.paid,
# customer.subscription.deleted).
MATHIZ_BILLING_PROVIDER=
# MATHIZ_STRIPE_SECRET_KEY=sk_test_...      # Stripe secret API key
# MATHIZ_STRIPE_WEBHOOK_SECRET=whsec_...    # webhook endpoint signing secret
# MATHIZ_PUBLIC_BASE_URL=https://mathiz.example.com   # for checkout redirects
# MATHIZ_BILLING_PRICE_EXPLORER=price_...
# MATHIZ_BILLING_PRICE_VOYAGER=price_...
# MATHIZ_BILLING_PRICE_ARMADA=price_...
# MATHIZ_BILLING_PRICE_TOPUP_100=price_...

# --- Product analytics (optional) ---
# PostHog project API key + ingestion host. Both unset (the default) =
# analytics fully off: the SPA never loads any analytics code. Child
# identity (names, profile IDs, PINs) is NEVER sent to analytics — child
# usage is tracked only at the family level. The host is server-side only:
# the server proxies browser events through same-origin /relay (so
# ad blockers can't drop them) and never exposes this URL to the SPA.
# See specs/16-analytics.md.
# MATHIZ_POSTHOG_API_KEY=phc_...
# MATHIZ_POSTHOG_HOST=https://us.i.posthog.com   # default when key is set

# --- LLM provider (same as local mode) ---
# One of: GEMINI_API_KEY / OPENAI_API_KEY / ANTHROPIC_API_KEY / OPENROUTER_API_KEY
# or the MATHIZ_* variants (see README).
GEMINI_API_KEY=
