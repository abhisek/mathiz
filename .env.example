# Configuration for `mathiz serve` (the SaaS server).
# Copy to .env and `set -a; source .env; set +a` (or use your process manager).

# --- Database (required) ---
# Dev: local PostgreSQL from `make dev-db`.
# Prod: Supabase's connection string or any hosted PostgreSQL.
MATHIZ_DATABASE_URL=postgres://mathiz:mathiz@localhost:5432/mathiz?sslmode=disable

# --- Supabase auth (parents) ---
# Project URL: used for JWKS verification, issuer validation, and SPA boot config.
MATHIZ_SUPABASE_URL=https://your-project.supabase.co
# Anon (publishable) key: served to the SPA; public by design.
MATHIZ_SUPABASE_ANON_KEY=your-anon-key
# Legacy JWT secret (Project Settings → API → JWT Secret). Enables HS256
# verification. Optional if your project uses asymmetric signing keys (JWKS).
MATHIZ_SUPABASE_JWT_SECRET=

# --- Server ---
MATHIZ_SERVER_ADDR=:8080
# MATHIZ_MAX_SESSIONS=100
# MATHIZ_SESSION_IDLE_MINUTES=30
# MATHIZ_CORS_ORIGINS=            # only for split SPA deployments

# --- LLM provider (same as local mode) ---
# One of: GEMINI_API_KEY / OPENAI_API_KEY / ANTHROPIC_API_KEY / OPENROUTER_API_KEY
# or the MATHIZ_* variants (see README).
GEMINI_API_KEY=
